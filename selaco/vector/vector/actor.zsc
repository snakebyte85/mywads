Class VectorAmmoPrize: VectorPrize {

  default {
    tag "$VECTOR_PRIZE_AMMO";
    Inventory.PickupSound "ARMOR/PICKUP";
    VectorPrize.tier 1;
    VectorPrize.category "weapon";
  }

  override void PostBeginPlay() {
    super.PostBeginPlay();

    AttachedActor sub;
    for(int i=0;i<3;i++) {
      sub = AttachedActor(Actor.spawn("VectorAmmoPrizeSub"..string.format("%i",i+1), self.pos));
      sub.attachedActor=self;
    }
  }

  override void DoPickupSpecial(Actor toucher) {
    let player = players[consolePlayer].mo;

    if(player.countInv("RoaringCricket")>0) {
      player.GiveInventory("PistolReserve", Inventory(GetDefaultByType("PistolReserve")).MaxAmount/2);
    }

    if(player.countInv("SMG")>0 || player.countInv("Rifle")>0) {
      player.GiveInventory("RifleReserve", Inventory(GetDefaultByType("RifleReserve")).MaxAmount/2);
    }
        
    if(player.countInv("Shot_gun")>0) {
      player.GiveInventory("ShotgunReserve", Inventory(GetDefaultByType("ShotgunReserve")).MaxAmount/2);
    }

    if(player.countInv("GrenadeLauncher")>0) {
      player.GiveInventory("GLFragReserve",2);
      player.GiveInventory("GLIceReserve",2);
      player.GiveInventory("GLAcidReserve",2);
    }
        
    if(player.countInv("Nailgun")>0) {
      player.GiveInventory("NailgunReserve", Inventory(GetDefaultByType("NailgunReserve")).MaxAmount/2);
    }

    if(player.countInv("PlasmaRifle")>0) {
      player.GiveInventory("PlasmaReserve", Inventory(GetDefaultByType("PlasmaReserve")).MaxAmount/2);
    }

    if(player.countInv("DMR")>0) {
      player.GiveInventory("MarksmanRifleReserve", Inventory(GetDefaultByType("MarksmanRifleReserve")).MaxAmount/2);
    }

  }

  states {
  Spawn:
    TNT1 A -1;
    loop;
  }
}

Class VectorWeaponPrize: VectorPrize abstract {

  default {
    //SelacoItem.pickupType "RoaringCricket";
    //tag "$WEAPON_ROARINGCRICKET";
    Inventory.PickupSound "ITEM/WPNFINDOLD";
    VectorPrize.tier 1;
    VectorPrize.category "weapon";
  }

  override void DoPickupSpecial(Actor toucher) {
    toucher.GiveInventory(pickupType, 1);
  }

  override bool CanPickup(Actor toucher) {
    return toucher.countinv(pickupType) == 0 && super.CanPickup(toucher);
  }
}

