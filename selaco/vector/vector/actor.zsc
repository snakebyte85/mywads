Class AttachedActor: Actor {

  Default {
    Radius 0;
    Height 0;
    +NOGRAVITY;
    +NOBLOCKMAP;
    +NOTELEPORT;
  }
  Actor attachedActor;

  override void tick() {
    if(attachedActor) {
      SetOrigin(attachedActor.pos, false);
      angle=attachedActor.angle;
    } else{
      destroy();
    }
  }

  states{
  Spawn:
    VOXE L 0;
    loop;
  }
}

