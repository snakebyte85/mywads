class VectorPerk : Inventory {
  
  int wavesLeft;
  int duration;
  property duration: duration;

  default {
    tag "";
    VectorPerk.duration -1;
  }

  override void SetGiveAmount(Actor receiver, int amount, bool givecheat) {
    self.ActivatePerk();
    wavesLeft=duration;
    Console.printf("SetGiveAmount %i in %s. Waveleft=%i and duration=%i", amount, self.getClassName(), wavesLeft, duration);
    super.SetGiveAmount(receiver, amount, givecheat);
  }

  override void DepleteOrDestroy() {
    Console.printf("DepleteorDestroy in %s", self.getClassName());
    self.DeactivatePerk();
    super.DepleteOrDestroy();
  }
  
  virtual void ActivatePerk() { }

  virtual void DeactivatePerk() { }
}

class VectorDoubleDamagePerk: VectorPerk {

  Default {
    tag "$VECTOR_PRIZE_DOUBLE_DAMAGE";
    VectorPerk.duration 1;
  }

  override void ModifyDamage (int damage, Name damageType, out int newdamage, bool passive, Actor inflictor, Actor source, int flags) {
    if (!passive && damage > 0) {
      Console.printf("Setting new damage from %s to %s", inflictor.getClassName(), source.getClassName());
        newdamage = max(1, ApplyDamageFactors(GetClass(), damageType, damage, damage * 2));        
    }
  }
}

Class VectorBunnyHopperPerk: VectorPerk {

  default {
    tag "$VECTOR_PRIZE_BUNNY_HOPPER";
    VectorPerk.duration 3;
  }

  override void ActivatePerk() {
    let player = players[consoleplayer].mo;
    player.GiveInventory("BunnyHopDuration", 0);
    player.FindInventory("BunnyHopDuration").maxAmount=0x7FFFFFFF;
    player.A_SetInventory("BunnyHopDuration", 0x7FFFFFFF);
  }

  override void DeactivatePerk() {
    players[consoleplayer].mo.A_SetInventory("BunnyHopDuration", 0);
  }
}

Class VectorRailgunPerk : VectorPerk {
  default {
    tag "$VECTOR_PRIZE_RAILGUN";
    VectorPerk.duration 1;
  }

  override void ActivatePerk() {
    players[consoleplayer].mo.giveInventory("RailgunAmmo", 100);
  }

  override void DeactivatePerk() {
    players[consoleplayer].mo.TakeInventory("Rail_gun", 1);
    players[consoleplayer].mo.A_SetInventory("RailgunAmmo", 0);
  }
}
