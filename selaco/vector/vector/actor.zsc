Class VectorWorkshop : Interactable {

  actor lid;
  float safeAreaRadius;
  property SafeAreaRadius: safeArearadius;

  Default {
    scale 1.0;
    radius 50;
    +USESPECIAL;
    +DONTTHRUST ;    
    activation THINGSPEC_SWITCH;
    +NOGRAVITY;
    Tag "$VECTOR_WORKSHOP";
    VectorWorkshop.SafeareaRadius 500;
  }

  override void PostBeginPlay() {
    bool success;
    [success,lid] = A_SPAWNITEMEX("ChestlidActor", flags:SXF_SETMASTER);
    lid.A_WARP(AAPTR_MASTER, -17, 0, 23, -90, WARPF_INTERPOLATE | WARPF_COPYPITCH | WARPF_NOCHECKPOSITION );
    for(int x=0;x<360;x+=4) {
      actor safearea;
      bool succ;
      [succ, safearea] = A_SPAWNITEMEX("VectorSafeArea", safeAreaRadius, 0, 2, angle:x, flags:SXF_SETMASTER);
      if(safearea) {
          VectorSafeArea(safearea).master = self;
          safearea.SetOrigin((safearea.pos.xy, safearea.floorz), false);
        }
    }

  }

  void Delete() {
    lid.destroy();
    destroy();
  }

  override void deactivate(actor deactivator) {
    activate(deactivator);
  }

  override void activate(actor activator) {
    VectorEventHandler.Instance().showVectorWorkshopMenu();
  }

}

class VectorSafeArea : actor {

  actor master;

    default {
        +FLATSPRITE;
        +NOGRAVITY;
        +NOBLOCKMAP;
        radius 5;
        scale 0.2;
        Alpha 0.25;
    }

    override void tick() {
      super.tick();

      if(!master) {
          destroy();
      }
    }
    States {
        Spawn: 
            EXPR B 1 BRIGHT;
            loop;
    }
}

Class VectorPrize: SelacoItem abstract {

  int tier;
  string category;
  string perk;
  bool oneTimeOnly;
  string description;

  property tier: tier;
  property category: category;
  property perk: perk;
  property oneTimeOnly: oneTimeOnly;
  property description: description;
  

  Default {
    tag "this should not appear!";
    scale 1.0;
    radius 25;
    VectorPrize.tier 1;
    VectorPrize.category "misc";
    VectorPrize.perk "";
    +WALLSPRITE;
    VectorPrize.oneTimeOnly false;
  }

  // No pickup via touch
  override bool CanPickup(Actor toucher) {
    bool perkActive=false;
    if(perk) {
      perkActive=VectorEventHandler.Instance().isPerkActive(perk);
    }
    return toucher is 'PlayerPawn' && !perkActive && !pickupIsTouchBased;
  }

  // rotating
  override void tick() {
    A_SETANGLE(angle+3);
  }

  override void DoPickupSpecial(Actor toucher) {
    if(perk) {
      VectorEventHandler.Instance().ActivatePerk(perk);
    }

    super.DoPickupSpecial(toucher);
  }

  states {
  Spawn:
    VOXE L -1;
    loop;
  Pickup:
    TNT1 A 1{
      invoker.destroy();
    }
    goto pickupsuccess;
  }
}

Class VectorHealthPrize: VectorPrize {

  default {
    tag "$VECTOR_PRIZE_HEALTH";
    VectorPrize.description "$VECTOR_PRIZE_HEALTH_DESCRIPTION";
    Inventory.Pickupsound "pickup/medkit";
    VectorPrize.tier 1;
    VectorPrize.category "stats";
  }

  override void DoPickupSpecial(Actor toucher) {
    toucher.A_SetHealth(toucher.GetMaxHealth());
    if(toucher is 'Dawn' && Random(1,100) <= 25) {
      Dawn dawn = dawn(toucher);
      dawn.HealTick(5);
      dawn.doHealthRelief();
    }
  }

  override bool CanPickup(Actor toucher) {
    return toucher.health < toucher.GetMaxHealth() && super.CanPickup(toucher);
  }
}

Class VectorSuperHealthPrize: VectorPrize {

  default {
    tag "$VECTOR_PRIZE_SUPER_HEALTH";
    VectorPrize.description "$VECTOR_PRIZE_SUPER_HEALTH_DESCRIPTION";
    Inventory.Pickupsound "pickup/medkit";
    VectorPrize.tier 2;
    VectorPrize.category "stats";
  }

  override void DoPickupSpecial(Actor toucher) {
    toucher.A_SetHealth(toucher.GetMaxHealth()+100);
    if(toucher is 'Dawn' && Random(1,100) <= 70) {
      Dawn dawn = dawn(toucher);
      dawn.HealTick(5);
      dawn.doHealthRelief();
    }
  }

  override bool CanPickup(Actor toucher) {
    return toucher.health < (toucher.GetMaxHealth()+100) && super.CanPickup(toucher);
  }
}

Class VectorHealthUpgradePrize: VectorPrize {

  default {
    tag "$VECTOR_PRIZE_HEALTH_UPGRADE";
    VectorPrize.description "$VECTOR_PRIZE_HEALTH_UPGRADE_DESCRIPTION";
    Inventory.Pickupsound "item/healpickup";
    VectorPrize.tier 3;
    VectorPrize.category "stats";
  }

  override void DoPickupSpecial(Actor toucher) {
    if(toucher.getMaxHealth() <= 200) {
      PlayerPawn(toucher).maxhealth = toucher.getmaxHealth() + 25;
    }
    toucher.A_SetHealth(toucher.GetMaxHealth());
    if(toucher is 'Dawn') {
      Dawn dawn = dawn(toucher);
      dawn.HealTick(5);
      dawn.doHealthRelief();
    }
  }

  override bool CanPickup(Actor toucher) {
    return (toucher.GetMaxHealth() <= 200 || toucher.health < toucher.GetMaxHealth()) && super.CanPickup(toucher);
  }
}

Class VectorArmorPrize: VectorPrize {

