Class VectorGrenadesPrize: VectorPrize {

  default {
    tag "$VECTOR_PRIZE_GRENADES";
    VectorPrize.description "$VECTOR_PRIZE_GRENADES_DESCRIPTION";
    Inventory.PickupSound "GRNPIN";
    VectorPrize.tier 1;
    VectorPrize.category "stats";
  }

  override void PostBeginPlay() {
    super.PostBeginPlay();

    AttachedActor sub;
    for(int i=0;i<3;i++) {
      sub = AttachedActor(Actor.spawn("VectorGrenadesPrizeSub"..string.format("%i",i+1), self.pos));
      sub.attachedActor=self;
    }
  }

  override void DoPickupSpecial(Actor toucher) {
    let player = players[consolePlayer].mo;
    player.GiveInventory("HandGrenadeAmmo", 2);
    player.GiveInventory("IceGrenadeAmmo", 1);
    player.GiveInventory("MineAmmo", 1);     
  }

  override bool CanPickup(Actor toucher) {
    Inventory frags = toucher.FindInventory("HandGrenadeAmmo");
    Inventory iceFrags = toucher.FindInventory("IceGrenadeAmmo");
    Inventory mines = toucher.FindInventory("MineAmmo");

    return !(frags && frags.Amount >= frags.maxAmount && iceFrags && iceFrags.Amount >= iceFrags.MaxAmount && mines && mines.Amount >= mines.maxAmount) && super.CanPickup(toucher);
  }

  states {
  Spawn:
    TNT1 A -1;
    loop;
  }
}

